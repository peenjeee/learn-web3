# === BNB Smart Chain Testnet (chainId 97) ===
BSC_TESTNET_RPC=https://bsc-testnet-rpc.publicnode.com

# Etherscan V2 API key (satu key jalan di semua chain, termasuk BNB Testnet). Buat verify.
ETHERSCAN_API_KEY=isi_etherscan_v2_api_key_kamu

# Private key wallet DEV (isinya cuma tBNB, JANGAN wallet utama). Dipakai script deploy buat sign.
PRIVATE_KEY=0xisi_private_key_wallet_dev

# Alamat RewardToken hasil DeployRewardToken. Isi SETELAH deploy token; dipakai DeployBountyEscrow.
REWARD_TOKEN=0xisi_alamat_reward_token_setelah_deploy
